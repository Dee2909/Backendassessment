# ─────────────────────────────────────────────────────────────────────────────
# Finance Dashboard Backend — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env directly.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Secret used to sign JWT tokens — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-secret"

# Port the server listens on (Render sets this automatically)
PORT=5001

# Deployed frontend URL — restrict CORS in production
# Set this to your Vercel app URL, e.g. https://finance-dashboard.vercel.app
FRONTEND_URL=
